rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isCoupleMember(coupleId) {
      return request.auth != null && (
        get(/databases/$(database)/documents/couples/$(coupleId)).data.partner1Id == request.auth.uid
        || get(/databases/$(database)/documents/couples/$(coupleId)).data.partner2Id == request.auth.uid
      );
    }

    match /users/{userId} {
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null
        && (request.auth.uid == userId
          || (resource.data.coupleId != null && isCoupleMember(resource.data.coupleId))
          || resource.data.inviteCode != null);
    }

    match /couples/{coupleId} {
      allow create: if request.auth != null
        && request.resource.data.partner1Id == request.auth.uid;

      allow read: if request.auth != null
        && (isCoupleMember(coupleId)
          || resource.data.status == 'pending'
          || resource.data.status == 'solo');

      allow update: if isCoupleMember(coupleId)
        || (request.auth != null
            && resource.data.partner2Id == null
            && request.resource.data.partner2Id == request.auth.uid);

      allow delete: if isCoupleMember(coupleId);

      match /{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }
    }
  }
}
